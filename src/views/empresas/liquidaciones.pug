extends ../layout

block contenido
  .page-header
    h2 Liquidaciones
    p Seleccione una empresa para generar liquidaciones o ver reportes.
  br
  table
    thead
      tr
        th Razón Social
        th CUIT
        th Contacto
        th Empleados
        th Acciones
    tbody
      each empresa in empresas
        tr
          td= empresa.razonSocial
          td= empresa.cuit
          td= empresa.contacto
          td= empresa.cantidadEmpleados
          td
            .acciones
              a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones` title="Ver cálculo")
                i.fas.fa-calculator
              a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones/guardadas` title="Guardadas")
                i.fas.fa-download 
              a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones/reporte` title="Reporte")
                i.fas.fa-clipboard-list
      if empresas.length === 0
        tr
          td(colspan="5" style="text-align:center;color:#999") No hay empresas registradas
