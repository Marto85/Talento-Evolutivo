extends ../layout

block contenido
  .page-header
    h2 Liquidaciones
    p Seleccione una empresa para generar liquidaciones o ver reportes.
  br
  table
    thead
      tr
        th Razón Social
        th CUIT
        th Contacto
        th Empleados
    tbody
      each empresa in empresas
        tr(style="cursor:pointer" onclick=`window.location='/empresas/${empresa.id}'`)
          td= empresa.razonSocial
          td= empresa.cuit
          td= empresa.contacto
          td= empresa.cantidadEmpleados
      if empresas.length === 0
        tr
          td(colspan="4" style="text-align:center;color:#999") No hay empresas registradas
