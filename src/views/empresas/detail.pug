extends ../layout

block contenido
  a.btn-back(href="/empresas")
    i.fas.fa-arrow-left
    |  Volver a Empresas
  .page-header
    h2= empresa.razonSocial
    .acciones
      a.btn.btn-primary(href=`/empresas/${empresa.id}/empleados`) Ver empleados
      a.btn(href=`/empresas/${empresa.id}/liquidaciones` style="background:#1f2d3d;color:#fff") Liquidaciones
      a.btn.btn-warning(href=`/empresas/${empresa.id}/liquidaciones/reporte`) Reportes
  br
  .card
    table
      tbody
        tr
          td
            strong CUIT
          td= empresa.cuit
        tr
          td
            strong Contacto
          td= empresa.contacto
        tr
          td
            strong Email
          td= empresa.email
        tr
          td
            strong Activa
          td
            span(class="badge " + (empresa.activa ? "badge-si" : "badge-no"))= empresa.activa ? "Sí" : "No"
        tr
          td
            strong Fecha de alta
          td= empresa.fechaAlta ? new Date(empresa.fechaAlta).toLocaleDateString('es-AR') : '—'
        tr
          td
            strong Empleados
          td= empresa.cantidadEmpleados
