extends ../layout

block contenido
  .page-header
    h2 Administrar Usuarios
    button.btn.btn-primary(type="button" onclick="openModal('modal-nuevo-usuario')") + Nuevo Usuario
  if error
    .error-list
      p= error
  if usuarios && usuarios.length
    table.admin-users
      thead
        tr
          th Usuario
          th Rol
          th Acciones
      tbody
        each u in usuarios
          tr
            td= u.user
            td= u.role
            td
              form(method="POST" action=`/admin/users/${u._id}/role` class="acciones")
                input(type="hidden" name="_csrf" value=csrfToken)
                select(name="role")
                  option(value="empleado" selected=(u.role==='empleado')) Empleado
                  option(value="auditor" selected=(u.role==='auditor')) Auditor
                  option(value="admin" selected=(u.role==='admin')) Admin
                button.btn-icon(type="submit" title="Guardar rol")
                  i.fas.fa-save
                if locals.authUserId !== String(u._id)
                  button.btn-icon.icon-danger(type="button" data-id=u._id data-nombre=u.user title="Eliminar usuario" onclick="openDeleteModal(this)")
                    i.fas.fa-trash
  else
    p No hay usuarios.

  //- Modal Nuevo Usuario
  #modal-nuevo-usuario.modal-overlay(style="display:none")
    .modal-box
      h3 Nuevo Usuario
      if locals.errores && locals.modalAbierto === 'modal-nuevo-usuario'
        .error-list
          each e in errores
            p= e
      form(method="POST" action="/admin/users/nuevo")
        input(type="hidden" name="_csrf" value=csrfToken)
        .campo
          label Usuario
          input(type="text" name="user" value=locals.lastUser || "" required autofocus)
        .campo
          label Password
          input(type="password" name="password" required)
        .campo
          label Confirmar Password
          input(type="password" name="confirm" required)
        .campo
          label Rol
          select(name="role")
            option(value="empleado") Empleado
            option(value="auditor") Auditor
            option(value="admin") Admin
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-nuevo-usuario')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-primary(type="submit") Guardar

  //- Modal Eliminar Usuario
  #modal-delete.modal-overlay(style="display:none")
    .modal-box
      h3 Confirmar eliminación
      p#delete-msg ¿Eliminar este usuario?
      form#delete-form(method="POST" action="")
        input(type="hidden" name="_csrf" value=csrfToken)
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-delete')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-danger(type="submit") Eliminar

  script.
    function openModal(id) {
      document.getElementById(id).style.display = 'flex';
    }
    function closeModal(id) {
      document.getElementById(id).style.display = 'none';
    }
    function openDeleteModal(btn) {
      const id = btn.dataset.id;
      const nombre = btn.dataset.nombre;
      document.getElementById('delete-msg').textContent = '¿Eliminar "' + nombre + '"?';
      document.getElementById('delete-form').action = '/admin/users/' + id + '/eliminar';
      openModal('modal-delete');
    }
    document.querySelectorAll('.modal-overlay').forEach(function(el) {
      el.addEventListener('click', function(e) {
        if (e.target === el) closeModal(el.id);
      });
    });
    var _modalAbierto = '!{locals.modalAbierto || ""}';
    if (_modalAbierto) openModal(_modalAbierto);
