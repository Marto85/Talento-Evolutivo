extends ../layout

block contenido
  a.btn-back(href=`/empresas/${empresaId}/empleados`)
    i.fas.fa-arrow-left
    |  Volver a empleados
  .page-header
    h2= empleado.nombre + " " + empleado.apellido
    .acciones
      button.btn.btn-primary(type="button" onclick="openModal('modal-liquidar')") Generar Liquidación
      button.btn.btn-secondary(type="button" onclick="openModal('modal-editar')") Editar
  br
  .card
    table
      tbody
        tr
          td
            strong DNI
          td= empleado.dni
        tr
          td
            strong Puesto
          td= empleado.puesto
        tr
          td
            strong Salario Base
          td= "$" + empleado.salarioBase.toLocaleString("es-AR")
        tr
          td
            strong Empresa
          td
            a(href=`/empresas/${empresaId}`)= empresa.razonSocial
        tr
          td
            strong Activo
          td
            span(class="badge " + (empleado.activo ? "badge-si" : "badge-no"))= empleado.activo ? "Sí" : "No"
        tr
          td
            strong Fecha de ingreso
          td= empleado.fechaIngreso ? new Date(empleado.fechaIngreso).toLocaleDateString('es-AR') : '—'
  br
  h3(style="margin-bottom:14px") Historial de liquidaciones
  if liquidaciones && liquidaciones.length
    table
      thead
        tr
          th Período
          th Bruto
          th Neto
          th Fecha guardado
          th Acciones
      tbody
        each item in liquidaciones
          tr
            td= item.periodo
            td= item.bruto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.neto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.createdAt.toLocaleDateString('es-AR')
            td
              .acciones
                a.btn-icon(href=`/empresas/${empresaId}/liquidaciones/${empleado.id}/recibo?periodo=${item.periodo}` title="Ver recibo")
                  i.fas.fa-file-alt
  else
    p(style="color:#999;font-size:0.9rem") No hay liquidaciones guardadas para este empleado.

  //- Modal Editar Empleado
  #modal-editar.modal-overlay(style="display:none")
    .modal-box
      h3 Editar Empleado
      if locals.errores && locals.modalAbierto === 'modal-editar'
        .error-list
          each e in errores
            p= e
      form(method="POST" action=`/empresas/${empresaId}/empleados/${empleado.id}/editar`)
        input(type="hidden" name="_csrf" value=csrfToken)
        .campo
          label Nombre
          input(type="text" name="nombre" value=empleado.nombre required)
        .campo
          label Apellido
          input(type="text" name="apellido" value=empleado.apellido required)
        .campo
          label DNI
          input(type="text" name="dni" value=empleado.dni required)
        .campo
          label Puesto
          input(type="text" name="puesto" value=empleado.puesto required)
        .campo
          label Salario Base
          input(type="number" name="salarioBase" value=empleado.salarioBase required min="0" step="1000")
        .campo
          label Fecha de ingreso
          - var fi = empleado.fechaIngreso ? new Date(empleado.fechaIngreso) : null
          - var fiDia = fi ? fi.getUTCDate() : ''
          - var fiMes = fi ? fi.getUTCMonth() + 1 : ''
          - var fiAnio = fi ? fi.getUTCFullYear() : ''
          .fecha-ingreso-selects
            select(name="fechaDia" required)
              option(value="" disabled selected=(fiDia==='')) Día
              - for (var d = 1; d <= 31; d++)
                option(value=d selected=(fiDia===d))= d
            select(name="fechaMes" required)
              option(value="" disabled selected=(fiMes==='')) Mes
              each m in [['1','Enero'],['2','Febrero'],['3','Marzo'],['4','Abril'],['5','Mayo'],['6','Junio'],['7','Julio'],['8','Agosto'],['9','Septiembre'],['10','Octubre'],['11','Noviembre'],['12','Diciembre']]
                option(value=m[0] selected=(String(fiMes)===m[0]))= m[1]
            input(type="number" name="fechaAnio" placeholder="Año" value=fiAnio min="1900" max=new Date().getFullYear() required)
        .campo
          label.checkbox-label
            input(type="checkbox" name="activo" checked=empleado.activo)
            |  Activo
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-editar')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-primary(type="submit") Guardar

  //- Modal Calcular sueldo
  #modal-liquidar.modal-overlay(style="display:none")
    .modal-box
      h3 Generar Liquidación
      p(style="color:#5f7482;font-size:0.88rem;margin-bottom:16px")= empleado.nombre + ' ' + empleado.apellido
      form#liquidar-form(method="GET" action="")
        .campo
          label Mes
          select(name="mes")
            - var meses = [['01','Enero'],['02','Febrero'],['03','Marzo'],['04','Abril'],['05','Mayo'],['06','Junio'],['07','Julio'],['08','Agosto'],['09','Septiembre'],['10','Octubre'],['11','Noviembre'],['12','Diciembre']]
            each m in meses
              option(value=m[0])= m[1]
        .campo
          label Año
          input(type="number" name="anio" min="2000" max="2099" required)
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-liquidar')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-primary(type="submit") Ver liquidación

  //- Modal Eliminar
  #modal-delete.modal-overlay(style="display:none")
    .modal-box
      h3 Confirmar eliminación
      p ¿Eliminar a #{empleado.nombre} #{empleado.apellido}?
      form(method="POST" action=`/empresas/${empresaId}/empleados/${empleado.id}/eliminar`)
        input(type="hidden" name="_csrf" value=csrfToken)
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-delete')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-danger(type="submit") Eliminar

  script.
    var _empresaId = '!{empresaId}';
    var _empleadoId = '!{empleado.id}';
    var _now = new Date();
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    document.querySelectorAll('.modal-overlay').forEach(function(el) {
      el.addEventListener('click', function(e) { if (e.target === el) closeModal(el.id); });
    });
    // Preseleccionar mes y año actuales en el modal de liquidar
    var form = document.getElementById('liquidar-form');
    form.querySelector('[name="mes"]').value = String(_now.getMonth() + 1).padStart(2, '0');
    form.querySelector('[name="anio"]').value = _now.getFullYear();
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var mes = this.querySelector('[name="mes"]').value;
      var anio = this.querySelector('[name="anio"]').value;
      window.location.href = '/empresas/' + _empresaId + '/liquidaciones/' + _empleadoId + '?periodo=' + anio + '-' + mes;
    });
