extends ../layout

block contenido
  a.btn-back(href=`/empresas/${empresaId}/empleados`)
    i.fas.fa-arrow-left
    |  Volver a empleados
  .page-header
    h2= empleado.nombre + " " + empleado.apellido
    .acciones
      button.btn.btn-primary(type="button" onclick="openModal('modal-liquidar')") Calcular sueldo
      a.btn.btn-secondary(href=`/empresas/${empresaId}/empleados/${empleado.id}/editar`) Editar
  br
  .card
    table
      tbody
        tr
          td
            strong ID
          td= empleado.id
        tr
          td
            strong DNI
          td= empleado.dni
        tr
          td
            strong Puesto
          td= empleado.puesto
        tr
          td
            strong Salario Base
          td= "$" + empleado.salarioBase.toLocaleString("es-AR")
        tr
          td
            strong Empresa
          td
            a(href=`/empresas/${empresaId}`)= empresa.razonSocial
        tr
          td
            strong Activo
          td
            span(class="badge " + (empleado.activo ? "badge-si" : "badge-no"))= empleado.activo ? "Sí" : "No"
        tr
          td
            strong Fecha de ingreso
          td= empleado.fechaIngreso
  br
  h3(style="margin-bottom:14px") Historial de liquidaciones
  if liquidaciones && liquidaciones.length
    table
      thead
        tr
          th Período
          th Bruto
          th Neto
          th Fecha guardado
          th Acciones
      tbody
        each item in liquidaciones
          tr
            td= item.periodo
            td= item.bruto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.neto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.createdAt.toLocaleDateString('es-AR')
            td
              .acciones
                a.btn-icon(href=`/empresas/${empresaId}/liquidaciones/${empleado.id}/recibo?periodo=${item.periodo}` title="Ver recibo")
                  i.fas.fa-file-alt
  else
    p(style="color:#999;font-size:0.9rem") No hay liquidaciones guardadas para este empleado.

  //- Modal Calcular sueldo
  #modal-liquidar.modal-overlay(style="display:none")
    .modal-box
      h3 Calcular sueldo
      p(style="color:#5f7482;font-size:0.88rem;margin-bottom:16px")= empleado.nombre + ' ' + empleado.apellido
      form#liquidar-form(method="GET" action="")
        .campo
          label Mes
          select(name="mes")
            - var meses = [['01','Enero'],['02','Febrero'],['03','Marzo'],['04','Abril'],['05','Mayo'],['06','Junio'],['07','Julio'],['08','Agosto'],['09','Septiembre'],['10','Octubre'],['11','Noviembre'],['12','Diciembre']]
            each m in meses
              option(value=m[0])= m[1]
        .campo
          label Año
          input(type="number" name="anio" min="2000" max="2099" required)
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-liquidar')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-primary(type="submit") Ver liquidación

  //- Modal Eliminar
  #modal-delete.modal-overlay(style="display:none")
    .modal-box
      h3 Confirmar eliminación
      p ¿Eliminar a #{empleado.nombre} #{empleado.apellido}?
      form(method="POST" action=`/empresas/${empresaId}/empleados/${empleado.id}/eliminar`)
        input(type="hidden" name="_csrf" value=csrfToken)
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-delete')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-danger(type="submit") Eliminar

  script.
    var _empresaId = '!{empresaId}';
    var _empleadoId = '!{empleado.id}';
    var _now = new Date();
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    document.querySelectorAll('.modal-overlay').forEach(function(el) {
      el.addEventListener('click', function(e) { if (e.target === el) closeModal(el.id); });
    });
    // Preseleccionar mes y año actuales en el modal de liquidar
    var form = document.getElementById('liquidar-form');
    form.querySelector('[name="mes"]').value = String(_now.getMonth() + 1).padStart(2, '0');
    form.querySelector('[name="anio"]').value = _now.getFullYear();
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var mes = this.querySelector('[name="mes"]').value;
      var anio = this.querySelector('[name="anio"]').value;
      window.location.href = '/empresas/' + _empresaId + '/liquidaciones/' + _empleadoId + '?periodo=' + anio + '-' + mes;
    });
