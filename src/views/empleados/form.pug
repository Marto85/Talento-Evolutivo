extends ../layout

block contenido
  h2= titulo
  .card
    form(method="POST" action=accion)
      .campo
        label Nombre
        input(type="text" name="nombre" value=empleado ? empleado.nombre : "" required)
      .campo
        label Apellido
        input(type="text" name="apellido" value=empleado ? empleado.apellido : "" required)
      .campo
        label DNI
        input(type="text" name="dni" value=empleado ? empleado.dni : "" required)
      .campo
        label Empresa
        select(name="empresaId" required)
          option(value="" disabled selected=!empleado) Seleccioná una empresa
          each empresa in empresas
            option(value=empresa.id selected=empleado && empleado.empresaId === empresa.id)= empresa.razonSocial
      .campo
        label Puesto
        input(type="text" name="puesto" value=empleado ? empleado.puesto : "" required)
      .campo
        label Salario Base
        input(type="number" name="salarioBase" value=empleado ? empleado.salarioBase : "" required min="0" step="1000")
      if empleado
        .campo
          label.checkbox-label
            input(type="checkbox" name="activo" checked=empleado.activo)
            | Activo
      .form-acciones
        button.btn.btn-primary(type="submit") Guardar
        a.btn(href="/empleados" style="background:#95a5a6;color:white") Cancelar
