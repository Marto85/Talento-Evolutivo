extends ../layout

block contenido
  a.btn-back(href=`/empresas/${empresa.id}`)
    i.fas.fa-arrow-left
    |  Volver a #{empresa.razonSocial}
  .page-header
    h2 Liquidaciones — #{empresa.razonSocial}
    button.btn.btn-primary(type="button" onclick="openModal('modal-nueva-liq')") + Generar nueva
  br
  if liquidaciones && liquidaciones.length
    table
      thead
        tr
          th Período
          th Empleado
          th Bruto
          th Neto
          th Fecha
          th Acciones
      tbody
        each item in liquidaciones
          tr
            td= item.periodo
            td= item.empleadoId ? item.empleadoId.nombre + ' ' + item.empleadoId.apellido : '—'
            td= item.bruto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.neto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.createdAt.toLocaleDateString('es-AR')
            td
              - var empId = item.empleadoId && item.empleadoId._id ? item.empleadoId._id : item.empleadoId
              .acciones
                a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones/${empId}/recibo?periodo=${item.periodo}` title="Ver recibo")
                  i.fas.fa-file-alt
                a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones/${empId}/recibo?periodo=${item.periodo}&png=1` title="Descargar PNG" target="_blank")
                  i.fas.fa-image
  else
    p(style="color:#999;font-size:0.9rem") No hay liquidaciones guardadas para esta empresa.

  //- Modal Nueva Liquidación
  #modal-nueva-liq.modal-overlay(style="display:none")
    .modal-box
      h3 Nueva liquidación
      form#form-nueva-liq
        .campo
          label Empleado
          select#sel-empleado(name="empleadoId" required)
            option(value="" disabled selected) Seleccioná un empleado...
            each emp in empleados
              option(value=emp.id)= emp.apellido + ', ' + emp.nombre + ' — ' + emp.puesto
        .campo
          label Mes
          select#sel-mes(name="mes")
            option(value="01") Enero
            option(value="02") Febrero
            option(value="03") Marzo
            option(value="04") Abril
            option(value="05") Mayo
            option(value="06") Junio
            option(value="07") Julio
            option(value="08") Agosto
            option(value="09") Septiembre
            option(value="10") Octubre
            option(value="11") Noviembre
            option(value="12") Diciembre
        .campo
          label Año
          input#sel-anio(type="number" name="anio" min="2000" max="2099" required)
        .form-acciones
          button.btn(type="button" onclick="closeModal('modal-nueva-liq')" style="background:#95a5a6;color:white") Cancelar
          button.btn.btn-primary(type="submit") Ver liquidación

  script.
    var _empresaId = '!{empresa.id}';
    var _now = new Date();
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    document.querySelectorAll('.modal-overlay').forEach(function(el) {
      el.addEventListener('click', function(e) { if (e.target === el) closeModal(el.id); });
    });
    // Preseleccionar mes y año actuales al abrir
    document.getElementById('sel-mes').value = String(_now.getMonth() + 1).padStart(2, '0');
    document.getElementById('sel-anio').value = _now.getFullYear();
    document.getElementById('form-nueva-liq').addEventListener('submit', function(e) {
      e.preventDefault();
      var empleadoId = document.getElementById('sel-empleado').value;
      if (!empleadoId) return;
      var mes = document.getElementById('sel-mes').value;
      var anio = document.getElementById('sel-anio').value;
      window.location.href = '/empresas/' + _empresaId + '/liquidaciones/' + empleadoId + '?periodo=' + anio + '-' + mes;
    });
