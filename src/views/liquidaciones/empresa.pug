extends ../layout

block contenido
  a.btn-back(href=`/empresas/${empresa.id}`)
    i.fas.fa-arrow-left
    |  Volver a #{empresa.razonSocial}
  .page-header
    h2 Liquidaciones — #{empresa.razonSocial}
    a.btn.btn-primary(href=`/empresas/${empresa.id}/liquidaciones/nueva`) + Generar nueva
  br
  if liquidaciones && liquidaciones.length
    table
      thead
        tr
          th Período
          th Empleado
          th Bruto
          th Neto
          th Fecha
          th Acciones
      tbody
        each item in liquidaciones
          tr
            td= item.periodo
            td= item.empleadoId ? item.empleadoId.nombre + ' ' + item.empleadoId.apellido : '—'
            td= item.bruto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.neto.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })
            td= item.createdAt.toLocaleDateString('es-AR')
            td
              .acciones
                a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones/${item.empleadoId?._id || item.empleadoId}/recibo?periodo=${item.periodo}` title="Ver recibo")
                  i.fas.fa-file-alt
                a.btn-icon(href=`/empresas/${empresa.id}/liquidaciones/${item.empleadoId?._id || item.empleadoId}/recibo?periodo=${item.periodo}&png=1` title="Descargar PNG" target="_blank")
                  i.fas.fa-image
  else
    p(style="color:#999;font-size:0.9rem") No hay liquidaciones guardadas para esta empresa.
