      .social-links a:hover { background: #f08a2b; }
      .page-loader { position: fixed; inset: 0; display: none; align-items: center; justify-content: center; background: rgba(255,255,255,0.82); backdrop-filter: blur(2px); z-index: 2000; }
      .page-loader.is-visible { display: flex; }
      .page-loader-box { min-width: 220px; padding: 22px 26px; border-radius: 10px; background: white; box-shadow: 0 10px 30px rgba(0,0,0,0.16); text-align: center; }
      .page-loader-spinner { width: 38px; height: 38px; margin: 0 auto 12px; border-radius: 50%; border: 4px solid #d6eaf8; border-top-color: #176b87; animation: spin 0.75s linear infinite; }
      .page-loader-text { font-size: 0.95rem; color: #1f2d3d; font-weight: 600; }
      body.loading { cursor: progress; }
      body.loading .btn, body.loading .btn-icon { pointer-events: none; opacity: 0.7; }
      @keyframes spin { to { transform: rotate(360deg); } }
      @media (max-width: 860px) {
