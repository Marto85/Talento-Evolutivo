doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Talento Evolutivo S.A.
    meta(name="csrf-token" content=csrfToken)
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap")
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Poppins', Arial, sans-serif; background: #f5f5f5; color: #333; }
      header { background: #2c3e50; color: white; padding: 15px 30px; }
      header h1 { font-size: 1.2rem; }
      .header-bar { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      nav { background: #34495e; padding: 0 30px; }
      nav a { display: inline-block; color: #ecf0f1; padding: 12px 16px; text-decoration: none; font-size: 0.9rem; }
      nav a:hover { background: #2c3e50; }
      main { padding: 30px; max-width: 1000px; margin: 0 auto; }
      .auth-main { min-height: calc(100vh - 90px); display: flex; align-items: center; justify-content: center; }
      h2 { margin-bottom: 20px; color: #2c3e50; }
      table { width: 100%; border-collapse: collapse; background: white; border-radius: 6px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
      th { background: #2c3e50; color: white; padding: 12px 15px; text-align: left; font-size: 0.85rem; }
      td { padding: 11px 15px; border-bottom: 1px solid #eee; font-size: 0.9rem; }
      tr:last-child td { border-bottom: none; }
      tr:hover td { background: #f9f9f9; }
      .btn { display: inline-block; padding: 7px 14px; border-radius: 4px; font-size: 0.85rem; cursor: pointer; text-decoration: none; border: none; }
      .btn-primary { background: #2980b9; color: white; }
      .btn-primary:hover { background: #2471a3; }
      .btn-warning { background: #e67e22; color: white; }
      .btn-warning:hover { background: #d35400; }
      .btn-danger { background: #e74c3c; color: white; }
      .btn-danger:hover { background: #c0392b; }
      .acciones { display: flex; gap: 6px; align-items: center; }
      .card { background: white; padding: 25px; border-radius: 6px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); max-width: 500px; }
      .campo { margin-bottom: 16px; }
      label { display: block; font-size: 0.85rem; font-weight: bold; margin-bottom: 5px; color: #555; }
      input[type=text], input[type=email], input[type=number], input[type=password], select { width: 100%; padding: 9px 11px; border: 1px solid #ccc; border-radius: 4px; font-size: 0.9rem; }
      input:focus, select:focus { outline: none; border-color: #2980b9; }
      .checkbox-label { display: flex; align-items: center; gap: 8px; font-weight: bold; font-size: 0.9rem; }
      .form-acciones { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }
      .badge { display: inline-block; padding: 3px 9px; border-radius: 12px; font-size: 0.75rem; font-weight: bold; }
      .badge-si { background: #d5f5e3; color: #1e8449; }
      .badge-no { background: #fadbd8; color: #922b21; }
      .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
      .modal-box { background: white; padding: 30px; border-radius: 8px; width: 100%; max-width: 460px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
      .modal-box h3 { margin-bottom: 20px; color: #2c3e50; }
      .btn-icon { background: none; border: none; cursor: pointer; padding: 5px 7px; border-radius: 4px; font-size: 1rem; color: #555; text-decoration: none; display: inline-flex; align-items: center; }
      .btn-icon:hover { background: #eee; color: #2c3e50; }
      .btn-icon.icon-danger:hover { background: #fadbd8; color: #e74c3c; }
      .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      .page-header h2 { margin-bottom: 0; }
      .btn-back { display: inline-flex; align-items: center; gap: 6px; color: #666; text-decoration: none; font-size: 0.85rem; margin-bottom: 14px; }
      .btn-back:hover { color: #2c3e50; }
      .error-list { background: #fadbd8; border-left: 3px solid #e74c3c; padding: 10px 14px; border-radius: 4px; margin-bottom: 16px; }
      .error-list p { color: #922b21; font-size: 0.85rem; margin: 2px 0; }
      .login-shell { width: 100%; display: flex; justify-content: center; }
      .login-card { width: 100%; max-width: 420px; }
      .login-copy { font-size: 0.92rem; color: #666; margin-bottom: 18px; }
      .page-loader { position: fixed; inset: 0; display: none; align-items: center; justify-content: center; background: rgba(255,255,255,0.82); backdrop-filter: blur(2px); z-index: 2000; }
      .page-loader.is-visible { display: flex; }
      .page-loader-box { min-width: 220px; padding: 22px 26px; border-radius: 10px; background: white; box-shadow: 0 10px 30px rgba(0,0,0,0.16); text-align: center; }
      .page-loader-spinner { width: 38px; height: 38px; margin: 0 auto 12px; border-radius: 50%; border: 4px solid #d6eaf8; border-top-color: #2980b9; animation: spin 0.75s linear infinite; }
      .page-loader-text { font-size: 0.95rem; color: #2c3e50; font-weight: 600; }
      body.loading { cursor: progress; }
      body.loading .btn,
      body.loading .btn-icon { pointer-events: none; opacity: 0.7; }
      @keyframes spin { to { transform: rotate(360deg); } }
  body(data-auth-required=locals.authRequired === false ? "false" : "true" data-auth-page=locals.authPage ? "true" : "false")
    header
      .header-bar
        h1 Talento Evolutivo S.A. — Sistema de Gestión de Haberes
        if !locals.authPage
          button#logout-button.btn(type="button" style="background:#c0392b;color:white") Logout
    if !locals.authPage
      nav
        a(href="/empresas") Empresas
    main(class=locals.authPage ? "auth-main" : "")
      block contenido
    #page-loader.page-loader(aria-hidden="true")
      .page-loader-box
        .page-loader-spinner
        p.page-loader-text Procesando...
    script.
      document.addEventListener('DOMContentLoaded', () => {
        const authPage = document.body.dataset.authPage === 'true';
        const pageLoader = document.getElementById('page-loader');
        const logoutButton = document.getElementById('logout-button');
        let isSubmitting = false;

        const syncAuthUi = () => {
          if (!logoutButton) return;
          logoutButton.style.display = authPage ? 'none' : 'inline-flex';
        };

        syncAuthUi();

        if (logoutButton) {
          logoutButton.addEventListener('click', async () => {
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
            try {
              await fetch('/logout', {
                method: 'POST',
                credentials: 'same-origin',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRF-Token': csrfToken
                }
              });
            } catch (error) {
            } finally {
              localStorage.removeItem('isLogged');
              localStorage.removeItem('loggedUser');
              localStorage.removeItem('authToken');
              window.location.replace('/login');
            }
          });
        }

        const showPageLoader = () => {
          if (!pageLoader) return;
          pageLoader.classList.add('is-visible');
          pageLoader.setAttribute('aria-hidden', 'false');
          document.body.classList.add('loading');
        };

        const hidePageLoader = () => {
          if (!pageLoader) return;
          pageLoader.classList.remove('is-visible');
          pageLoader.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('loading');
          isSubmitting = false;
          document.querySelectorAll('form button[type="submit"], form input[type="submit"]').forEach((control) => {
            control.disabled = false;
          });
        };

        const cuitInputs = document.querySelectorAll('input[name="cuit"]');
        cuitInputs.forEach(input => {
          input.setAttribute('maxlength', '13');
          input.addEventListener('input', function(e) {
            // Limpia todo lo que no sea número y corta estrictamente a 11 dígitos
            let val = this.value.replace(/\D/g, '').substring(0, 11);
            let formatted = val;
            
            // Aplica los guiones automáticamente
            if (val.length > 2 && val.length <= 10) {
              formatted = val.substring(0, 2) + '-' + val.substring(2);
            } else if (val.length > 10) {
              formatted = val.substring(0, 2) + '-' + val.substring(2, 10) + '-' + val.substring(10);
            }
            this.value = formatted;
            
            // Frena el formulario si no está completo (así no se borran los datos)
            const cuitRegex = /^\d{2}-\d{7,8}-\d{1}$/;
            if (this.value && !cuitRegex.test(this.value)) {
              this.setCustomValidity("El CUIT debe estar completo (ej: 30-12345678-9)");
            } else {
              this.setCustomValidity(""); // CUIT válido, quita el error
            }
          });
        });

        document.querySelectorAll('form').forEach((form) => {
          form.addEventListener('submit', (event) => {
            if ((form.method || '').toLowerCase() === 'get') return;
            if (!form.checkValidity()) return;
            if (isSubmitting) {
              event.preventDefault();
              return;
            }

            isSubmitting = true;
            form.querySelectorAll('button[type="submit"], input[type="submit"]').forEach((control) => {
              control.disabled = true;
            });
            showPageLoader();
          });
        });

        window.addEventListener('pageshow', hidePageLoader);
      });
