  body(data-auth-required=locals.authRequired === false ? "false" : "true" data-auth-page=locals.authPage ? "true" : "false")
    header.site-header
      .navbar
        a.brand(href="/" aria-label="Talento Evolutivo - Home")
          span.brand-mark TE
          span.brand-text
            span.brand-name Talento Evolutivo
            span.brand-subtitle Gestion de haberes
        nav.nav-links(aria-label="Navegacion principal")
          if locals.isAuthenticated
            a(class=locals.currentPath.startsWith("/empresas") && !locals.currentPath.startsWith("/empresas/liquidaciones") ? "is-active" : "" href="/empresas")
              i.fas.fa-building
              | Empresas
            a.nav-cta(class=locals.currentPath.startsWith("/empresas/liquidaciones") ? "is-active" : "" href="/empresas/liquidaciones")
              i.fas.fa-file-invoice-dollar
              | Liquidaciones
            button#logout-button.nav-danger(type="button")
              i.fas.fa-right-from-bracket
              | Logout
          else
            a(class=locals.currentPath === "/" ? "is-active" : "" href="/")
              i.fas.fa-house
              | Home
            a(href="/#nosotros")
              i.fas.fa-building
              | Acerca de nosotros
            a(href="/#servicios")
              i.fas.fa-briefcase
              | Servicios
            a(href="/#clientes")
              i.fas.fa-star
              | Clientes
            a(href="/#contacto")
              i.fas.fa-envelope
              | Contacto
            a.nav-cta(class=locals.currentPath === "/login" ? "is-active" : "" href="/login")
              i.fas.fa-right-to-bracket
              | Ingresar
    main(class=locals.homePage ? "home-main" : (locals.authPage ? "auth-main" : ""))
