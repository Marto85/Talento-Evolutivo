      .btn { display: inline-flex; align-items: center; justify-content: center; gap: 7px; padding: 8px 14px; border-radius: 6px; font-size: 0.85rem; cursor: pointer; text-decoration: none; border: none; min-height: 36px; }
      .btn-primary { background: #176b87; color: white; }
      .btn-primary:hover { background: #12566c; }
