      .nav-links a, .nav-links button { min-height: 36px; display: inline-flex; align-items: center; gap: 7px; padding: 8px 11px; border: 0; border-radius: 6px; background: transparent; color: #34495e; font: inherit; font-size: 0.86rem; text-decoration: none; cursor: pointer; white-space: nowrap; }
      .nav-links a:hover, .nav-links button:hover, .nav-links .is-active { background: #e9f3f6; color: #176b87; }
