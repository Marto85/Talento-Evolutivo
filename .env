# Para desarrollo local (si tienes MongoDB instalado):
MONGODB_URI=mongodb://localhost:27017/talento-evolutivo

# Para usar MongoDB Atlas (cloud gratuito) después:
# 1. Ve a https://www.mongodb.com/cloud/atlas
# 2. Crea una cuenta gratuita
# 3. Crea un cluster gratuito
# 4. Reemplaza tu_usuario, tu_contraseña y atlas_cluster_url:
# MONGODB_URI=mongodb+srv://tu_usuario:tu_contraseña@atlas_cluster_url/?appName=Cluster0

PORT=3000
NODE_ENV=development
